name: hallucinateapi
default_branch: main
config:
  description: "Implements every GET and POST operation in an OpenAPI spec by using each operation's description as the LLM instruction, validating inputs, and returning schema-constrained JSON that behaves like a normal API response."
  license: MIT
  language: go
  release: docker-go
  justfile: true
  release_github: false
  status: wip
  codecov:
    enabled: false
  docs:
    enabled: true
    domain: hallucinateapi.unitvectorylabs.com
